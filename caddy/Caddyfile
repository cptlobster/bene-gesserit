:8080 {
    reverse_proxy {$ANUBIS_ENDPOINT}
}

:8081 {
    @honeypot {
        path /sicily/*
        path /asia/*
    }

    handle @honeypot {
        reverse_proxy {$IOCAINE_ENDPOINT}
    }

    handle /robots.txt {
        root * /etc/caddy/static
        file_server browse
    }

    handle {
        reverse_proxy {$TARGET_ENDPOINT}
    }
}